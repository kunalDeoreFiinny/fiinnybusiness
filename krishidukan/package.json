{
  "name": "krishidukan",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:migrate": "pnpm --filter @krishidukan/api exec prisma migrate dev",
    "db:seed": "pnpm --filter @krishidukan/api exec prisma db seed",
    "db:studio": "pnpm --filter @krishidukan/api exec prisma studio",
    "db:reset": "pnpm --filter @krishidukan/api exec prisma migrate reset"
  },
  "devDependencies": {
    "@types/node": "^22.7.5",
    "eslint": "^9.11.1",
    "prettier": "^3.3.3",
    "turbo": "^2.3.3",
    "typescript": "^5.6.2"
  },
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "dependencies": {
    "pnpm": "^11.0.8"
  }
}
