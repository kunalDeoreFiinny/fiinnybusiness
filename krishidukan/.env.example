# ─── services/api ────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://krishidukan_user:PASSWORD@localhost:5432/krishidukan_db"
GOOGLE_APPLICATION_CREDENTIALS="/absolute/path/to/krishidukan-service-account.json"
FIREBASE_PROJECT_ID="lifemap-72b21"
FIREBASE_STORAGE_BUCKET="lifemap-72b21.appspot.com"
JWT_SECRET="replace-with-256-bit-random-secret"
JWT_EXPIRES_IN="7d"
PORT=3001
NODE_ENV=development
CORS_ORIGINS="http://localhost:5173,http://localhost:5174,http://localhost:5175"
DEFAULT_SEARCH_RADIUS_KM=10
DEFAULT_SEARCH_LIMIT=20

# ─── apps/shop-portal, apps/admin, apps/erp-web ──────────────────────────────
VITE_FIREBASE_API_KEY="your-firebase-api-key"
VITE_FIREBASE_AUTH_DOMAIN="lifemap-72b21.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="lifemap-72b21"
VITE_FIREBASE_STORAGE_BUCKET="lifemap-72b21.appspot.com"
VITE_FIREBASE_MESSAGING_SENDER_ID="your-sender-id"
VITE_FIREBASE_APP_ID="your-app-id"
VITE_API_BASE_URL="http://localhost:3001"

# ─── apps/farmer-app (Expo) ───────────────────────────────────────────────────
EXPO_PUBLIC_FIREBASE_API_KEY="your-firebase-api-key"
EXPO_PUBLIC_FIREBASE_PROJECT_ID="lifemap-72b21"
EXPO_PUBLIC_API_BASE_URL="http://localhost:3001"
