# Customer-web environment variables
# Copy to `.env` for local dev. Vite exposes any var prefixed with VITE_ to client code.

# Base URL for the KrishiDukan API. Leave blank to use bundled mock data.
VITE_API_BASE_URL=

# Optional Firebase config (set when swapping the mock auth/data layer for Firebase)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
